# ----------
# CONVEX CONFIGURATION
# ----------

# Your Convex Deployment ID (Format: dev:your-deployment-id)
# This is used by the Convex CLI for synchronization.
CONVEX_DEPLOYMENT=dev:your-deployment-id

# Public Convex URL (Found in Convex Dashboard -> Settings)
# Used by the frontend client to connect to the database.
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Optional: Next.js Site URL for production
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
